{
  "name": "recall-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:capacitor": "VITE_DEPLOY_TARGET=capacitor tsc --noEmit && VITE_DEPLOY_TARGET=capacitor vite build",
    "preview": "vite preview",
    "ios:setup": "npm run build:capacitor && npx cap add ios && npx cap sync ios",
    "ios:sync": "npm run build:capacitor && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@gsap/react": "^2.1.2",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "gsap": "^3.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recall-healthkit": "file:plugins/recall-healthkit",
    "recharts": "^2.13.3",
    "three": "^0.169.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "semver": "^7.8.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
